# Léa API - Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs

# OpenAI (obligatoire pour le chat)
OPENAI_API_KEY=sk-...

# Modèle OpenAI (optionnel)
LLM_MODEL=gpt-4o

# Base de données
# Option 1: SQLite (par défaut si POSTGRESQL non configuré)
DATABASE_URL=sqlite+aiosqlite:///./lea_api.db

# Option 2: PostgreSQL (prioritaire si DB_NAME est défini)
# DB_NAME=immoassist_db_v2
# DB_USER=postgres
# DB_PASSWORD=...
# DB_HOST=localhost
# DB_PORT=5432
