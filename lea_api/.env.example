# Léa API — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs

# ---------------------------------------------------------------------------
# Obligatoire
# ---------------------------------------------------------------------------
# OpenAI (chat, Realtime vocal, TTS)
OPENAI_API_KEY=sk-...

# Deepgram (STT temps réel — mode vocal WebSocket /ws/voice)
DEEPGRAM_API_KEY=...

# ---------------------------------------------------------------------------
# Base de données
# ---------------------------------------------------------------------------
# Option 1 : SQLite (défaut si PostgreSQL non configuré)
DATABASE_URL=sqlite+aiosqlite:///./lea_api.db

# Option 2 : PostgreSQL (prioritaire si DB_NAME est défini)
# DB_NAME=immoassist_db_v2
# DB_USER=postgres
# DB_PASSWORD=...
# DB_HOST=localhost
# DB_PORT=5432

# ---------------------------------------------------------------------------
# Optionnel
# ---------------------------------------------------------------------------
# Modèle LLM (défaut : gpt-4o)
# LLM_MODEL=gpt-4o

# Désactiver la transcription Whisper en Realtime si rate limit / erreurs
# REALTIME_DISABLE_TRANSCRIPTION=true

# Redis (session state — non utilisé par défaut)
# REDIS_URL=redis://localhost:6379
# USE_REDIS=false
