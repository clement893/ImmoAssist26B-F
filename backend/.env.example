# Léa Chat API - Environment variables

# Database: SQLite (simple) or PostgreSQL
# SQLite (no external DB needed):
DATABASE_URL=sqlite+aiosqlite:///./lea_chat.db

# PostgreSQL (if you prefer):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/modele

# Demo mode: use X-LEA-Demo-Token header instead of JWT
LEA_DEMO_TOKEN=your-secret-demo-token
LEA_DEMO_EMAIL=demo@test.com

# AI (OpenAI or Anthropic)
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
